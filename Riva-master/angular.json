{
    "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
    "version": 1,
    "cli": {
        "defaultCollection": "@angular/schematics",
        "analytics": false
    },
    "newProjectRoot": "projects",
    "projects": {
        "project-riva": {
            "projectType": "application",
            "schematics": {
                "@schematics/angular:component": {
                    "style": "css",
                    "type": "component"

                },
                "assets": [{
                        "glob": "**/*",
                        "input": "public"
                    },
                    "src/assets"
                ],
                "@schematics/angular:service": {
                    "type": "service"
                },
                "@schematics/angular:pipe": {
                    "type": "pipe"
                },
                "@schematics/angular:directive": {
                    "type": "directive"
                },
                "@schematics/angular:module": {
                    "type": "module"
                }
            },
            "root": "",
            "sourceRoot": "src",
            "prefix": "app",
            "architect": {
                "build": {
                    "builder": "@angular/build:application",
"options": {
  "browser": "src/main.ts",
  "tsConfig": "tsconfig.app.json",
  "inlineStyleLanguage": "css",
  "optimization": {
    "fonts": false
  },
  "assets": [
    {
      "glob": "**/*",
      "input": "public"
    },
    {
      "glob": "**/*",
      "input": "src/assets",
      "output": "assets"
    }
  ],
  "styles": [
    "node_modules/@fortawesome/fontawesome-free/css/all.min.css",
    "src/styles.css"
  ]
},
                    "configurations": {
                        "production": {
                            "budgets": [{
                                    "type": "initial",
                                    "maximumWarning": "1.2MB",
                                    "maximumError": "1.5MB"
                                },
                                {
                                    "type": "anyComponentStyle",
                                    "maximumWarning": "12kB",
                                    "maximumError": "16kB"
                                }
                            ],
                            "outputHashing": "all"
                        },
                        "development": {
                            "optimization": false,
                            "extractLicenses": false,
                            "sourceMap": true
                        }
                    },
                    "defaultConfiguration": "production"
                },
                "serve": {
                    "builder": "@angular/build:dev-server",
                    "configurations": {
                        "production": {
                            "buildTarget": "project-riva:build:production"
                        },
                        "development": {
                            "buildTarget": "project-riva:build:development"
                        }
                    },
                    "defaultConfiguration": "development"
                },
                "test": {
                    "builder": "@angular/build:unit-test",
                    "options": {
                        "runner": "karma",
                        "tsConfig": "tsconfig.spec.json",
                        "include": [
                            "src/app/riva-final-qa.spec.ts"
                        ],
                        "browsers": [
                            "ChromeHeadless"
                        ]
                    }
                }
            }
        }
    }
}
